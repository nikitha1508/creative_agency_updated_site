@model CreativeAgency.Web.Models.ContactFormModel
@{
    ViewData["Title"] = "Contact - Creative Agency";
    ViewData["Description"] = "Get in touch with Creative Agency. We'd love to hear about your project.";
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Contact</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Contact Content -->
<div class="container my-5">
    <h2 class="page-heading mb-4">Contact Us</h2>

    <!-- Success Message (shown after PRG redirect) -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-start gap-3 mb-4" role="alert">
            <div>
                <strong>&#10003; Enquiry submitted successfully!</strong><br />
                <span>Thank you for contacting us. We will get back to you soon.</span>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <a asp-controller="Contact" asp-action="Index" class="btn btn-primary">Send Another Enquiry</a>
    }
    else
    {
        <div class="row g-5">
            <!-- Contact Form -->
            <div class="col-lg-7">
                <form asp-controller="Contact" asp-action="Index" method="post" novalidate id="contactForm">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                    {
                        <div class="alert alert-danger py-2 mb-3">
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold">
                                First Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="FirstName" class="form-control" placeholder="John" autocomplete="given-name" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold">
                                Last Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="LastName" class="form-control" placeholder="Doe" autocomplete="family-name" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label fw-semibold">
                                Email <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Email" class="form-control" placeholder="john.doe@example.com" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="EnquiryType" class="form-label fw-semibold">
                                Enquiry Type <span class="text-danger">*</span>
                            </label>
                            <select asp-for="EnquiryType" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="General">General</option>
                                <option value="Services">Services</option>
                                <option value="Support">Support</option>
                                <option value="Partnership">Partnership</option>
                            </select>
                            <span asp-validation-for="EnquiryType" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Summary" class="form-label fw-semibold">
                                Summary <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Summary" class="form-control" rows="4"
                                      placeholder="I would like to know more about your services."></textarea>
                            <span asp-validation-for="Summary" class="text-danger small"></span>
                        </div>
                        <div class="col-12 mt-2">
                            <button type="submit" class="btn btn-primary px-4">Submit</button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Get In Touch Info -->
            <div class="col-lg-5">
                <div class="contact-info-box p-4 rounded h-100">
                    <h5 class="fw-bold mb-4">Get in Touch</h5>
                    <ul class="list-unstyled contact-info-list">
                        <li class="mb-4 d-flex align-items-start gap-3">
                            <span class="contact-info-icon">&#127968;</span>
                            <div>
                                <div class="fw-semibold mb-1">Address</div>
                                <span class="text-muted">123, Creative Street<br />New York, USA</span>
                            </div>
                        </li>
                        <li class="mb-4 d-flex align-items-start gap-3">
                            <span class="contact-info-icon">&#9993;</span>
                            <div>
                                <div class="fw-semibold mb-1">Email</div>
                                <span class="text-muted">info@creativeagency.com</span>
                            </div>
                        </li>
                        <li class="d-flex align-items-start gap-3">
                            <span class="contact-info-icon">&#9742;</span>
                            <div>
                                <div class="fw-semibold mb-1">Phone</div>
                                <span class="text-muted">+1 123 456 7890</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
