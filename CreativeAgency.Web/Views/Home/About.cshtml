@{
    ViewData["Title"] = "About";
    ViewData["Description"] = "We are a passionate team of designers, developers, and marketers committed to building creative digital experiences.";
}

<div id="aboutCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/hero.jpg" class="d-block w-100" alt="Slide 1">
        </div>
        <div class="carousel-item">
            <img src="~/images/service_seo_hero.jpg" class="d-block w-100" alt="Slide 2">
        </div>
        <div class="carousel-item">
            <img src="~/images/service_content_hero.jpg" class="d-block w-100" alt="Slide 3">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#aboutCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#aboutCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<h2>About Our Creative Agency</h2>

<section class="mb-4">
    <h4>Who We Are</h4>
    <p>We are a passionate team of designers, developers, and marketers committed to building creative digital experiences. Our mission is to help businesses stand out with cutting-edge design and innovative marketing strategies.</p>
</section>

<section class="mb-4">
    <h4>What We Do</h4>
    <p>From branding and web design to social media management and SEO, we offer a full range of services tailored to your business needs. We believe in delivering measurable results through collaboration and creativity.</p>
</section>