@{
    ViewData["Title"] = "About Us - Creative Agency";
    ViewData["Description"] = "Learn more about Creative Agency.";
}

<!-- Breadcrumb -->
<section class="breadcrumb-bar">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="breadcrumb-item active">About</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6 mb-4">

    <img src="~/images/service_content.jpg"
     class="img-fluid rounded shadow"
     alt="About Creative Agency" />


            </div>

            <div class="col-lg-6">

                <h2 class="page-heading">
                    About Our Agency
                </h2>

                <p>
                    Creative Agency provides innovative web design,
                    development, SEO, and digital marketing solutions
                    for businesses worldwide.
                </p>

                <p>
                    We focus on delivering high-quality digital experiences
                    that help brands grow online and achieve measurable success.
                </p>

                <a class="btn btn-primary">
                    Read More
                </a>

            </div>

        </div>

        <div class="row text-center mt-5 stats-row p-4">

            <div class="col-md-3">
                <h2 class="stat-number">120+</h2>
                <p class="stat-label">Projects</p>
            </div>

            <div class="col-md-3">
                <h2 class="stat-number">80+</h2>
                <p class="stat-label">Clients</p>
            </div>

            <div class="col-md-3">
                <h2 class="stat-number">15+</h2>
                <p class="stat-label">Awards</p>
            </div>

            <div class="col-md-3">
                <h2 class="stat-number">25+</h2>
                <p class="stat-label">Team Members</p>
            </div>

        </div>

    </div>
</section>