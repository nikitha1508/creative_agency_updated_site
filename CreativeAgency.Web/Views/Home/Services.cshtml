@{
    ViewData["Title"] = "Services";
    ViewData["Description"] = "Explore our SEO, content marketing, social media, and web development services.";
}

<h2 class="mb-4">Our Services</h2>

<div id="seo" class="row align-items-center mb-5">
    <div class="col-md-6">
        <img src="~/images/service_seo.jpg" class="img-fluid" alt="SEO Optimization">
    </div>
    <div class="col-md-6">
        <h3>SEO Optimization</h3>
        <p>Boost your website visibility and rankings with our expert SEO services. We specialize in keyword research, technical optimization, and link building strategies that help your website appear on the first page of search engine results.</p>
    </div>
</div>

<div id="content" class="row align-items-center mb-5 flex-md-row-reverse">
    <div class="col-md-6">
        <img src="~/images/service_content.jpg" class="img-fluid" alt="Content Marketing">
    </div>
    <div class="col-md-6">
        <h3>Content Marketing</h3>
        <p>We craft compelling content strategies that engage your audience and drive traffic. From blog posts and case studies to whitepapers and social media content, we create valuable and relevant material tailored to your brand voice.</p>
    </div>
</div>

<div id="social" class="row align-items-center mb-5">
    <div class="col-md-6">
        <img src="~/images/service_social.jpg" class="img-fluid" alt="Social Media Management">
    </div>
    <div class="col-md-6">
        <h3>Social Media Management</h3>
        <p>Expand your online presence through effective social media strategies. We manage your social profiles, create engaging posts, and analyze performance to ensure you're building lasting relationships with your audience.</p>
    </div>
</div>

<div id="web" class="row align-items-center mb-5 flex-md-row-reverse">
    <div class="col-md-6">
        <img src="~/images/service_web.jpg" class="img-fluid" alt="Web Development">
    </div>
    <div class="col-md-6">
        <h3>Web Development</h3>
        <p>Our development team builds responsive, SEO-friendly websites that provide seamless user experiences across all devices. Whether it's a corporate site or a custom application, we bring your digital vision to life.</p>
    </div>
</div>