@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<nav class="navbar navbar-expand-lg navbar-light bg-light px-3">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <img src="~/images/logo.png" alt="Logo" />
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link @(controller == "Home" && action == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="nav-item"><a class="nav-link @(controller == "Home" && action == "Services" ? "active" : "")" asp-controller="Home" asp-action="Services">Services</a></li>
            <li class="nav-item"><a class="nav-link @(controller == "Blog" ? "active" : "")" asp-controller="Blog" asp-action="Index">Blog</a></li>
            <li class="nav-item"><a class="nav-link @(controller == "Home" && action == "About" ? "active" : "")" asp-controller="Home" asp-action="About">About</a></li>
            <li class="nav-item"><a class="nav-link @(controller == "Contact" ? "active" : "")" asp-controller="Contact" asp-action="Index">Contact</a></li>
        </ul>
    </div>
</nav>
