@{
    ViewData["Title"] = ViewBag.Title;
    ViewData["Description"] = ViewBag.Title;
}

<section class="breadcrumb-bar">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Blog" asp-action="Index">Blog</a>
                </li>
                <li class="breadcrumb-item active">
                    @ViewBag.Title
                </li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">

        <h2>@ViewBag.Title</h2>

        <p class="text-muted">
            @ViewBag.Author | @ViewBag.Date
        </p>

        <img src="~/images/@ViewBag.Image"
             class="img-fluid rounded mb-4"
             alt="@ViewBag.Title" />

        <div style="white-space:pre-line; font-size:17px; line-height:1.8;">
            @ViewBag.Content
        </div>

        <a asp-controller="Blog"
           asp-action="Index"
           class="btn btn-primary mt-4">
            Back to Blog
        </a>

    </div>
</section>