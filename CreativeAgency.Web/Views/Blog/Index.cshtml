@{
    ViewData["Title"] = "Blog - Creative Agency";
    ViewData["Description"] = "Browse our latest articles and insights on SEO, content marketing, social media, and web development.";
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Blog</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Blog Listing -->
<div class="container my-5">
    <h2 class="page-heading mb-4">Blog</h2>

    <!-- Post 1 -->
    <div class="row g-4 mb-4 align-items-center blog-post-row">
        <div class="col-md-4">
            <a asp-controller="Blog" asp-action="Detail" asp-route-slug="10-tips-for-a-successful-business">
                <img src="~/images/service_web.jpg" class="img-fluid rounded blog-thumb" alt="10 Tips for a Successful Business" />
            </a>
        </div>
        <div class="col-md-8">
            <h5 class="fw-bold mb-1">
                <a asp-controller="Blog" asp-action="Detail" asp-route-slug="10-tips-for-a-successful-business">
                    10 Tips for a Successful Business
                </a>
            </h5>
            <p class="blog-meta text-muted small mb-2">Admin &nbsp;|&nbsp; May 20, 2026</p>
            <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
            <a asp-controller="Blog" asp-action="Detail" asp-route-slug="10-tips-for-a-successful-business" class="btn btn-primary btn-sm">Read More</a>
        </div>
    </div>

    <hr class="my-4" />

    <!-- Post 2 -->
    <div class="row g-4 mb-4 align-items-center blog-post-row">
        <div class="col-md-4">
            <a asp-controller="Blog" asp-action="Detail" asp-route-slug="how-to-improve-your-website-seo">
                <img src="~/images/service_seo.jpg" class="img-fluid rounded blog-thumb" alt="How to Improve Your Website SEO" />
            </a>
        </div>
        <div class="col-md-8">
            <h5 class="fw-bold mb-1">
                <a asp-controller="Blog" asp-action="Detail" asp-route-slug="how-to-improve-your-website-seo">
                    How to Improve Your Website SEO
                </a>
            </h5>
            <p class="blog-meta text-muted small mb-2">Admin &nbsp;|&nbsp; May 18, 2026</p>
            <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
            <a asp-controller="Blog" asp-action="Detail" asp-route-slug="how-to-improve-your-website-seo" class="btn btn-primary btn-sm">Read More</a>
        </div>
    </div>
</div>
